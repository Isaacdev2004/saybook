# API server (Render web service or local)
PORT=5000
GEMINI_API_KEY=
# Free-tier keys often have no quota on gemini-2.0-flash; use a current free-tier model or enable billing.
GEMINI_MODEL=gemini-2.5-flash

# Saybook Vite dev server port (do not reuse PORT — that is the API port)
VITE_DEV_PORT=5173

# Saybook app: API origin only when UI and API are on different hosts. Leave blank for local dev + Vite /api proxy.
VITE_API_BASE_URL=
# Optional override for Vite dev proxy target (defaults to http://127.0.0.1:$PORT)
VITE_DEV_API_URL=
# Optional Vite /api proxy timeout in ms (Gemini generation can take several minutes)
VITE_DEV_API_TIMEOUT_MS=600000
