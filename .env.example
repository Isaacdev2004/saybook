# API server (Render web service or local)
PORT=5000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Saybook app: API origin only (not the static site URL). Leave blank for local dev + Vite /api proxy.
VITE_API_BASE_URL=
# Optional override for Vite dev proxy target (defaults to http://127.0.0.1:$PORT)
VITE_DEV_API_URL=
